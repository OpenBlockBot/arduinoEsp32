{
  "name": "arduino-esp32",
  "version": "0.1.0",
  "author": "ArthurZheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openblock-plugin/arduinoEsp32.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "npx openblock-registry-cli dev",
    "build": "npx openblock-registry-cli build",
    "build:obfuscate": "npx openblock-registry-cli build --obfuscate",
    "publish": "npx openblock-registry-cli publish",
    "publish:dry": "npx openblock-registry-cli publish --dry-run",
    "validate": "npx openblock-registry-cli validate",
    "i18n:update": "npx openblock-registry-cli i18n update",
    "lint": "eslint . --ext .js --fix"
  },
  "openblock": {
    "name": "Esp32",
    "deviceId": "arduinoEsp32",
    "arch": [
      "arduino-esp32"
    ],
    "manufactor": "espressif",
    "learnMore": "https://docs.espressif.com/projects/esp-dev-kits/en/latest/esp32/index.html",
    "type": "arduino",
    "iconURL": "./assets/arduinoEsp32.png",
    "description": {
      "formatMessage": {
        "id": "arduinoEsp32.description",
        "default": "Wi-Fi & Bluetooth control board with rich functions."
      }
    },
    "bluetoothRequired": false,
    "serialportRequired": true,
    "defaultBaudRate": "115200",
    "internetConnectionRequired": false,
    "launchPeripheralConnectionFlow": true,
    "useAutoScan": false,
    "connectionIconURL": "./assets/arduinoEsp32-illustration.svg",
    "connectionSmallIconURL": "./assets/arduinoEsp32-small.svg",
    "main": "./src/arduinoEsp32.js",
    "generator": "./src/generator.js",
    "translations": "./src/translations.js",
    "toolchains": "arduino-esp32-esp32",
    "programMode": [
      "realtime",
      "upload"
    ],
    "tags": [
      "arduino"
    ],
    "helpLink": "https://wiki.openblock.cc/general-hardware-guidelines/boards/esp32",
    "libraries": "./libraries",
    "firmwares": [
      {
        "id": "standard",
        "name": "Firmata Standard",
        "file": "./firmwares/ConfigurableFirmata.ino.merged.bin"
      }
    ],
    "examples": [
      {
        "id": "blink",
        "name": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.blink.name",
            "default": "Blink"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.blink.description",
            "default": "Make the on-board LED blink."
          }
        },
        "file": "./examples/blink.ob"
      },
      {
        "id": "button",
        "name": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.button.name",
            "default": "Button"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.button.description",
            "default": "Light up the LED while a push button is pressed."
          }
        },
        "file": "./examples/button.ob"
      },
      {
        "id": "fade",
        "name": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.fade.name",
            "default": "Fade"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.fade.description",
            "default": "Smoothly fade an LED in and out using PWM."
          }
        },
        "file": "./examples/fade.ob"
      },
      {
        "id": "knob",
        "name": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.knob.name",
            "default": "Knob"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.knob.description",
            "default": "Control LED brightness with a potentiometer."
          }
        },
        "file": "./examples/knob.ob"
      },
      {
        "id": "servoSweep",
        "name": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.servoSweep.name",
            "default": "Servo Sweep"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.servoSweep.description",
            "default": "Sweep a servo back and forth between 0 and 180 degrees."
          }
        },
        "file": "./examples/servoSweep.ob"
      },
      {
        "id": "serialMonitor",
        "name": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.serialMonitor.name",
            "default": "Serial Monitor"
          }
        },
        "description": {
          "formatMessage": {
            "id": "arduinoEsp32.examples.serialMonitor.description",
            "default": "Print analog readings to the Serial Monitor every half second."
          }
        },
        "file": "./examples/serialMonitor.ob"
      }
    ]
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.3.0",
    "eslint-config-scratch": "^5.0.0",
    "husky": "^9.0.0"
  }
}
